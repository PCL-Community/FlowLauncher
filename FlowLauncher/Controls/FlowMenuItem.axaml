<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:c="using:FlowLauncher.Controls">

    <Design.PreviewWith>
        <c:FlowMenuItem/>
    </Design.PreviewWith>

    <Style Selector=":is(c|FlowMenuItem)">
        <!-- Set Defaults -->
        <Style Selector="^:pointerover, ^:focus">
            <Setter Property="PriorityBackgroundOpacity" Value=".15"/>
        </Style>
        <Style Selector="^:pressing, ^:checked">
            <Setter Property="PriorityBackgroundOpacity" Value=".3"/>
        </Style>
        <Setter Property="RightAreaTemplate">
            <ControlTemplate x:DataType="c:FlowMenuItem">
                <ItemsControl ItemsSource="{Binding ExtraControls}" x:Name="ExtraItemsContainer">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" DataContext="{Binding $parent[c:FlowMenuItem].DataContext}"
                                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Transitions><Transitions>
                        <DoubleTransition Property="Opacity" Duration="0:0:.1"/>
                    </Transitions></ItemsControl.Transitions>
                </ItemsControl>
            </ControlTemplate>
        </Setter>
        <Setter Property="CornerRadius" Value="0"/>
        <Setter Property="BackgroundOpacity" Value="0"/>
        <Setter Property="PressingForeground" Value="{DynamicResource FlowAccent}"/>
        <Setter Property="MinHeight" Value="30"/>
        <Setter Property="MinWidth" Value="100"/>
        <Setter Property="TextAlignment" Value="Left"/>
        <Style Selector="^ ItemsControl#ExtraItemsContainer">
            <Setter Property="Opacity" Value="0"/>
        </Style>
        <Style Selector="^:pointerover, ^:focus, ^:pressing, ^:checked">
            <Style Selector="^ ItemsControl#ExtraItemsContainer">
                <Setter Property="Opacity" Value="1"/>
            </Style>
        </Style>
    </Style>

</Styles>
