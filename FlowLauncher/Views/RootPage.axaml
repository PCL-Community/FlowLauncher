<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:FlowLauncher.ViewModels"
        xmlns:c="clr-namespace:FlowLauncher.Controls"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="FlowLauncher.Views.RootPage"
        x:DataType="vm:RootPageViewModel">
    <DockPanel>
        <!-- top bar -->
        <Border DockPanel.Dock="Top" Height="{StaticResource TopBarHeight}"
                Background="{DynamicResource FlowAccent}" PointerPressed="TopBar_OnPointerPressed">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                <StackPanel.Styles>
                    <Style>
                        <Style.Selector>
                        </Style.Selector>
                    </Style>
                </StackPanel.Styles>
                <c:FlowRadioButton Classes="TopBar" Icon="{StaticResource IconPlay}" Text="启动"/>
                <c:FlowRadioButton Classes="TopBar" Icon="{StaticResource IconDownload}" Text="安装"/>
                <c:FlowRadioButton Classes="TopBar" Icon="{StaticResource IconTools}" Text="工具"/>
                <c:FlowRadioButton Classes="TopBar" Icon="{StaticResource IconSettings}" Text="设置"/>
            </StackPanel>
        </Border>
        <!-- main content -->
        <Grid Background="{DynamicResource FlowBackground}" Opacity=".9">
        </Grid>
    </DockPanel>
</UserControl>
