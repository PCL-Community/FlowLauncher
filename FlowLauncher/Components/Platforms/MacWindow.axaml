<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:p="clr-namespace:FlowLauncher.Components.Platforms"
        xmlns:c="clr-namespace:FlowLauncher.Controls"
        xmlns:r="clr-namespace:FlowLauncher.Resources"
        xmlns:ui="clr-namespace:FlowLauncher.Components.UI"
        x:Class="FlowLauncher.Components.Platforms.MacWindow"
        Icon="/Assets/logo.ico" Title="{x:Static r:Strings.AppTitle}"
        MinWidth="900" MinHeight="540"
        Width="900" Height="540"
        DataContext="{Binding RelativeSource={RelativeSource Self}}"
        ExtendClientAreaToDecorationsHint="True">
    <Grid x:Name="BackgroundPanel">
        <ui:RootLayout ParentWindow="{Binding RelativeSource={RelativeSource AncestorType=p:BaseWindow}}"
                DataContext="{Binding RootLayout, RelativeSource={RelativeSource AncestorType=p:BaseWindow}}"/>
        <!-- topbar -->
        <Grid VerticalAlignment="Top" Height="{StaticResource TopBarHeight}">
            <!-- navigation controls -->
            <Grid Classes="Nav" x:Name="BackPanel" ColumnDefinitions="100,*,100" ColumnSpacing="10" Margin="8,4"
                    Opacity="{Binding RootLayout.HasLastPage, Converter={x:Static c:Converters.BoolToOpacity}}">
                <Grid.Styles>
                    <Style Selector="Grid.Nav">
                        <Setter Property="Transitions">
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:.1"/>
                            </Transitions>
                        </Setter>
                    </Style>
                </Grid.Styles>
                <Grid.RenderTransform>
                    <TranslateTransform X="-40" Y="0">
                        <TranslateTransform.Transitions>
                            <Transitions>
                                <DoubleTransition Property="X" Duration="0:0:.4"
                                        Easing="{StaticResource SpringEasing}"/>
                            </Transitions>
                        </TranslateTransform.Transitions>
                    </TranslateTransform>
                </Grid.RenderTransform>
                <!-- ReSharper disable Xaml.PossibleNullReferenceException -->
                <c:FlowButton Grid.Column="0" Classes="TopBar" VerticalAlignment="Bottom" HorizontalAlignment="Left"
                        Icon="{StaticResource IconArrowLeft}" Click="BackButton_OnClick"
                        IsEnabled="{Binding RootLayout.HasLastPage}"
                        Text="{Binding RootLayout.LastPage.Title}"
                        ToolTip.Tip="{Binding RootLayout.LastPage.Title}"
                        FontSize="10" IconWidth="8" Padding="4, 2"/>
                <!-- ReSharper restore Xaml.PossibleNullReferenceException -->
                <TextBlock Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                        Text="{Binding RootLayout.CurrentPagePreview.Title}" IsEnabled="False"
                        FontSize="16" Foreground="{DynamicResource FlowTopBarForeground}"/>
            </Grid>
            <!-- right extra contents -->
            <Grid HorizontalAlignment="Right" Margin="8,4">
                <!-- tasks button -->
                <c:FlowButton Classes="TopBar" VerticalAlignment="Center" Text="{x:Static r:Strings.PageNavTasks}"
                        Icon="{StaticResource IconCheckList}" Click="TasksButton_OnClick">
                    <c:FlowButton.IsChecked>
                        <MultiBinding Converter="{x:Static c:Converters.AllEqual}">
                            <Binding Path="RootLayout.CurrentPagePreview.Id"/>
                            <Binding Source="tasks"/>
                        </MultiBinding>
                    </c:FlowButton.IsChecked>
                </c:FlowButton>
            </Grid>
        </Grid>
    </Grid>
</Window>
